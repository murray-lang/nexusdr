{
  "radio": {
    "control": {
      "sinks": [
      	{
          "type": "funcube",
          "config": {
          }
        }
      ],
      "sources": [
        {
          "type": "digitalInputGroup",
          "config": {
            "inputs": [
              {
                    "type": "gpioRotaryEncoder",
                    "config": {
                      "gpioPins": [5, 6],
                      "settingPath": "rx.rf.offset"
                    }
              },
              {
                "type": "gpioRotaryEncoder",
                "config": {
                  "gpioPins": [20, 21],
                  "settingPath": "rx.rf.frequency"
                }
              }
            ]
          }
        }
      ]
    },
    "receiver": {
      "iqInput": {
        "soundApi": "alsa",
        "searchExpression": "FUNcube",
        "sampleRate": 192000,
        "channelCount": 2
      },
      "audioOutput": {
        "soundApi": "alsa",
        "searchExpression": "Default",
        "sampleRate": 48000,
        "format": "sint16"
      }
    }
  }
}
